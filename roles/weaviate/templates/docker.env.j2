# Weaviate Configuration
WEAVIATE_DOMAIN={{ weaviate_domain }}
WEAVIATE_VERSION={{ weaviate_build_version }}

# Weaviate Authentication
WEAVIATE_API_KEY={{ weaviate_api_key }}
WEAVIATE_API_USER={{ weaviate_api_user }}

# Weaviate Logging
WEAVIATE_LOG_LEVEL={{ weaviate_log_level }}

# Let's Encrypt Configuration
LETSENCRYPT_EMAIL={{ letsencrypt_email }}

# IP Whitelisting (Optional)
# Leave empty for public access with API key authentication
# Examples: "10.0.0.0/8,192.168.0.0/16" or "203.0.113.1/32"
ALLOWED_IPS={{ weaviate_allowed_ips }}

# Resource Limits - Traefik
TRAEFIK_CPU_LIMIT={{ weaviate_traefik_cpu_limit }}
TRAEFIK_MEMORY_LIMIT={{ weaviate_traefik_memory_limit }}
TRAEFIK_CPU_RESERVATION={{ weaviate_traefik_cpu_reservation }}
TRAEFIK_MEMORY_RESERVATION={{ weaviate_traefik_memory_reservation }}

# Resource Limits - Weaviate
WEAVIATE_CPU_LIMIT={{ weaviate_cpu_limit }}
WEAVIATE_MEMORY_LIMIT={{ weaviate_memory_limit }}
WEAVIATE_CPU_RESERVATION={{ weaviate_cpu_reservation }}
WEAVIATE_MEMORY_RESERVATION={{ weaviate_memory_reservation }}

# Resource Limits - Multi2vec-CLIP
CLIP_CPU_LIMIT={{ weaviate_multi2vec_cpu_limit }}
CLIP_MEMORY_LIMIT={{ weaviate_multi2vec_memory_limit }}
CLIP_CPU_RESERVATION={{ weaviate_multi2vec_cpu_reservation }}
CLIP_MEMORY_RESERVATION={{ weaviate_multi2vec_memory_reservation }}
