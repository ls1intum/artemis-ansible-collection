#!/bin/bash
#
# Restore a Weaviate filesystem backup.
#
# Managed by Ansible (ls1intum.artemis "weaviate" role) — DO NOT EDIT BY HAND.
#
# Backups are stored as native directories under the backup directory
# (backup-YYYYMMDD-HHMMSS). Legacy compressed backups (backup-*.tar.gz) are
# still supported: if only a tarball exists it is extracted in place first.
#
set -Eeuo pipefail

BACKUP_DIR="{{ weaviate_backup_directory }}"

list_backups() {
    echo "Available backups:"
    find "$BACKUP_DIR" -maxdepth 1 -regextype posix-extended \
        \( -type d -regex '.*/backup-[0-9]{8}-[0-9]{6}' \
           -o -type f -regex '.*/backup-[0-9]{8}-[0-9]{6}\.tar\.gz' \) \
        -printf '%f\n' 2>/dev/null | sed 's/\.tar\.gz$//' | sort -u | sed 's/^/  /' \
        || echo "  No backups found"
}

if [ -z "${1:-}" ]; then
    echo "Usage: ./restore.sh <backup-id>"
    echo ""
    list_backups
    exit 1
fi

BACKUP_ID="$1"
BACKUP_PATH="${BACKUP_DIR}/${BACKUP_ID}"
BACKUP_TARBALL="${BACKUP_DIR}/${BACKUP_ID}.tar.gz"

echo "Starting Weaviate restore..."
echo "Backup ID: ${BACKUP_ID}"

# Load environment variables (docker .env: KEY=value lines).
if [ ! -f .env ]; then
    echo "Error: .env file not found!"
    exit 1
fi
set -a
# shellcheck disable=SC1091
source .env
set +a

if [ -z "${WEAVIATE_API_KEY:-}" ] || [ -z "${WEAVIATE_DOMAIN:-}" ]; then
    echo "Error: WEAVIATE_API_KEY and WEAVIATE_DOMAIN must be set in .env"
    exit 1
fi

# Resolve the backup into a native directory under BACKUP_DIR.
if [ -d "$BACKUP_PATH" ]; then
    echo "Using native backup directory: ${BACKUP_PATH}"
elif [ -f "$BACKUP_TARBALL" ]; then
    echo "Extracting legacy tarball: ${BACKUP_TARBALL}"
    tar -xzf "$BACKUP_TARBALL" -C "$BACKUP_DIR"
    if [ ! -d "$BACKUP_PATH" ]; then
        echo "Error: tarball did not contain ${BACKUP_ID}"
        exit 1
    fi
else
    echo "Error: backup not found: ${BACKUP_PATH} (or ${BACKUP_TARBALL})"
    echo ""
    list_backups
    exit 1
fi

echo ""
echo "WARNING: This will replace all current data with the backup!"
echo "Press Ctrl+C to cancel, or type 'yes' to continue..."
read -r CONFIRM
if [ "$CONFIRM" != "yes" ]; then
    echo "Restore cancelled"
    exit 0
fi

# Initiate restore via Weaviate API. The backup directory is already mounted
# into the container, so no copying is required.
echo "Initiating restore..."
RESPONSE=$(curl --fail-with-body -sS --connect-timeout 10 --max-time 120 -w "\n%{http_code}" -X POST \
    "https://${WEAVIATE_DOMAIN}/v1/backups/filesystem/${BACKUP_ID}/restore" \
    -H "Authorization: Bearer ${WEAVIATE_API_KEY}" \
    -H "Content-Type: application/json") || true

HTTP_CODE=$(echo "$RESPONSE" | tail -n1)
BODY=$(echo "$RESPONSE" | sed '$d')

if [ "$HTTP_CODE" != "200" ]; then
    echo "Error: Failed to initiate restore (HTTP ${HTTP_CODE})"
    echo "$BODY"
    exit 1
fi

echo "Restore initiated successfully!"
echo "Waiting for restore to complete..."
MAX_RETRIES=60
RETRY_COUNT=0
STATUS=""

while [ "$RETRY_COUNT" -lt "$MAX_RETRIES" ]; do
    sleep 5
    STATUS_RESPONSE=$(curl --fail-with-body -sS --connect-timeout 10 --max-time 60 -w "\n%{http_code}" \
        "https://${WEAVIATE_DOMAIN}/v1/backups/filesystem/${BACKUP_ID}/restore" \
        -H "Authorization: Bearer ${WEAVIATE_API_KEY}") || true

    HTTP_CODE=$(echo "$STATUS_RESPONSE" | tail -n1)
    BODY=$(echo "$STATUS_RESPONSE" | sed '$d')

    if [ "$HTTP_CODE" == "200" ]; then
        STATUS=$(echo "$BODY" | jq -r '.status // empty')
        if [ "$STATUS" == "SUCCESS" ]; then
            echo "Restore completed successfully!"
            break
        elif [ "$STATUS" == "FAILED" ]; then
            echo "Error: Restore failed!"
            echo "$BODY"
            exit 1
        fi
    fi

    RETRY_COUNT=$((RETRY_COUNT + 1))
    echo "Restore in progress... (${RETRY_COUNT}/${MAX_RETRIES})"
done

if [ "$STATUS" != "SUCCESS" ]; then
    echo "Error: Restore timed out"
    exit 1
fi

echo ""
echo "Restore completed successfully!"
echo "  Backup ID: ${BACKUP_ID}"
echo ""
